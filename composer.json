{
    "name": "laravel/laravel",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.0.2",
        "aiz-packages/color-code-converter": "dev-main",
        "aiz-packages/combination-generate": "dev-main",
        "enshrined/svg-sanitize": "^0.15.4",
        "genealabs/laravel-sign-in-with-apple": "*",
        "guzzlehttp/guzzle": "^7.5",
        "intervention/image": "^2.5",
        "kreait/firebase-php": "^7.0",
        "kreait/laravel-firebase": "^5.8",
        "lab404/laravel-impersonate": "1.7.5",
        "laracasts/flash": "^3.2",
        "laravel-notification-channels/fcm": "^4.5",
        "laravel-notification-channels/webpush": "^9.0",
        "laravel/framework": "^11.0",
        "laravel/horizon": "^5.31",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.6",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.2",
        "lcobucci/jwt": "^5.0",
        "league/flysystem-aws-s3-v3": "^3.12",
        "maatwebsite/excel": "^3.1",
        "mercadopago/dx-php": "^2.5",
        "mpdf/mpdf": "^8.1",
        "netflie/whatsapp-cloud-api": "^2.2",
        "niklasravnsborg/laravel-pdf": "^4.1",
        "opcodesio/log-viewer": "^3.15",
        "predis/predis": "^2.1",
        "psr/log": "^2.0",
        "rmccue/requests": "^2.0",
        "simplesoftwareio/simple-qrcode": "*",
        "smsgateway24/smsgateway24-php-sdk": "^2.0",
        "spatie/cpu-load-health-check": "^1.0",
        "spatie/db-dumper": "^3.3",
        "spatie/laravel-health": "^1.34",
        "spatie/laravel-permission": "^6.9.0",
        "symfony/http-client": "^7.2",
        "symfony/mailgun-mailer": "^7.1",
        "twilio/sdk": "^6.44"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "barryvdh/laravel-ide-helper": "^3.1.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.1",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "autoload": {
        "classmap": [
            "database/seeders",
            "database/factories"
        ],
        "psr-4": {
            "App\\": "app/"
        },
        "files": ["app/Http/Helpers.php"]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
            ]
        }
    },
    "scripts": {
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "symfony/thanks": true
        }
    },
   "minimum-stability": "stable",
    "prefer-stable": true
}
